<idea-plugin>
    <id>com.orbenk.commit-ai</id>
    <name>Git Utils AI</name>
    <vendor>git-utils</vendor>
    <description><![CDATA[
        Dois botões na tela de commit do IntelliJ para geração de mensagens via Google Gemini AI:<br/>
        <ul>
            <li><b>Gerar com IA</b> — gera a mensagem a partir do diff staged atual (via Get-CommitMessage.ps1)</li>
            <li><b>Selecionar e Commitar com IA</b> — gera o diff dos arquivos selecionados no painel,
                gera a mensagem, adiciona os arquivos ao stage e realiza o commit</li>
        </ul>
        Configure a API Key em <b>Settings → Tools → Git Utils AI</b>.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>Git4Idea</depends>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Persiste configurações (caminho do script + API key) -->
        <applicationService
            serviceImplementation="com.orbenk.GitUtilsSettings"/>

        <!-- Página em Settings > Tools > Git Utils AI -->
        <applicationConfigurable
            parentId="tools"
            instance="com.orbenk.GitUtilsSettingsConfigurable"
            id="com.orbenk.settings"
            displayName="Git Utils AI"/>
    </extensions>

    <actions>
        <!-- Gera mensagem a partir do diff staged via Get-CommitMessage.ps1 -->
        <action id="GitUtils.GenerateCommitMessage"
                class="com.orbenk.GenerateCommitMessageAction"
                text="Gerar com IA"
                description="Gera mensagem de commit a partir do diff staged (Get-CommitMessage.ps1)">
            <add-to-group group-id="ChangesView.CommitToolbar" anchor="first"/>
        </action>

        <!-- Gera diff dos arquivos selecionados, gera mensagem e commita diretamente -->
        <action id="GitUtils.GenerateAndCommit"
                class="com.orbenk.GenerateAndCommitAction"
                text="Selecionar e Commitar com IA"
                description="Gera diff dos arquivos selecionados, cria a mensagem com IA e realiza o commit">
            <add-to-group group-id="ChangesView.CommitToolbar" anchor="after" relative-to-action="GitUtils.GenerateCommitMessage"/>
        </action>
    </actions>
</idea-plugin>
